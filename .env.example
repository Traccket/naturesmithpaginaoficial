# === Nature Smith — variables de entorno ===
# Copiar a .env.local y completar con datos reales.

# Dominio final en producción (sin slash final)
NEXT_PUBLIC_SITE_URL=https://naturesmith.com.co

# WhatsApp comercial (formato internacional sin +, ej: 573001234567)
NEXT_PUBLIC_WHATSAPP=573000000000

# Correo comercial
NEXT_PUBLIC_EMAIL=comercial@naturesmith.com.co

# Ciudad sede (se muestra en footer y schema)
NEXT_PUBLIC_CIUDAD=Bogotá, Colombia

# Redes sociales (dejar vacío si no aplica; se omiten del schema)
NEXT_PUBLIC_INSTAGRAM=
NEXT_PUBLIC_FACEBOOK=
NEXT_PUBLIC_TIKTOK=

# Cloudflare Turnstile (anti-spam del formulario). Si está vacío,
# el formulario funciona con honeypot + validaciones únicamente.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Webhook opcional para respaldo de leads (CRM, Sheets, Make, n8n...)
LEADS_WEBHOOK_URL=

# Almacén privado de leads (repositorio GitHub privado) + panel /panel
LEADS_GITHUB_TOKEN=
LEADS_REPO=usuario/repositorio-privado
ADMIN_PASSWORD=

# Activar Strict-Transport-Security cuando el SSL esté estable
SECURITY_HSTS=0
